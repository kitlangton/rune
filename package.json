{
  "name": "@kitlangton/rune",
  "version": "0.1.0",
  "description": "A confined TypeScript-shaped runtime for composing agent capabilities through one code tool.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/rune.js",
  "module": "./dist/rune.js",
  "types": "./dist/rune.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kitlangton/rune.git"
  },
  "homepage": "https://github.com/kitlangton/rune#readme",
  "bugs": {
    "url": "https://github.com/kitlangton/rune/issues"
  },
  "keywords": [
    "agents",
    "effect",
    "llm",
    "sandbox",
    "tools"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "types": "./dist/rune.d.ts",
      "import": "./dist/rune.js"
    },
    "./promise": {
      "types": "./dist/promise.d.ts",
      "import": "./dist/promise.js"
    },
    "./ai-sdk": {
      "types": "./dist/ai-sdk.d.ts",
      "import": "./dist/ai-sdk.js"
    },
    "./effect-ai": {
      "types": "./dist/effect-ai.d.ts",
      "import": "./dist/effect-ai.js"
    },
    "./policy": {
      "types": "./dist/policy.d.ts",
      "import": "./dist/policy.js"
    },
    "./clock": {
      "types": "./dist/clock.d.ts",
      "import": "./dist/clock.js"
    },
    "./store": {
      "types": "./dist/store.d.ts",
      "import": "./dist/store.js"
    },
    "./fs": {
      "types": "./dist/fs.d.ts",
      "import": "./dist/fs.js"
    },
    "./http": {
      "types": "./dist/http.d.ts",
      "import": "./dist/http.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "start": "bun run src/main.ts",
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "demo:dev": "vite --config vite.config.ts",
    "demo:build": "vite build --config vite.config.ts",
    "demo:preview": "vite preview --config vite.config.ts",
    "typecheck": "rm -rf dist site-dist && tsc --noEmit && tsc --noEmit -p site/tsconfig.json",
    "test": "bun test",
    "check:release": "bun run typecheck && bun run test && bun run build",
    "prepack": "bun run build",
    "prepublishOnly": "bun run check:release"
  },
  "devDependencies": {
    "@effect/language-service": "0.86.2",
    "@types/bun": "latest",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "effect": "^4.0.0-beta.74",
    "fast-check": "^4.8.0",
    "motion": "^12.40.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "vite": "^8.0.14"
  },
  "dependencies": {
    "acorn": "^8.15.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "ai": "^6.0.0",
    "effect": "^4.0.0-beta.74"
  },
  "peerDependenciesMeta": {
    "ai": {
      "optional": true
    }
  }
}
